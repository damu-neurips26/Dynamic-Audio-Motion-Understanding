  "url": "https://drive.google.com/drive/u/7/folders/1zbNvCbslQmNU0BWAEvimxQB6TMwM8mHi",
  "rai:dataBiases": "The data exhibits a selection bias towards standard European passenger vehicles from the VS13 dataset. The simulated portions assume idealized planar propagation which underrepresents complex urban or heavily obstructed scenarios.",
  "rai:dataLimitations": "The dataset is constrained to the acoustic profiles of 6 vehicle classes. It does not generalize to other vehicle types (e.g., heavy trucks) or non-vehicle sound sources. It is evaluated under specific synthetic physical conditions which may not capture all real-world environmental acoustic effects.",
  "rai:dataSocialImpact": "Positive impact: Enables rigorous evaluation of physical motion understanding in audio AI systems. Risks: Potential misuse for unauthorized tracking of vehicles. Mitigation: Released for academic research purposes under controlled access.",
  "rai:dataUseCases": "The dataset is intended to evaluate physical motion inference from sound, such as estimating continuous vehicle speed, direction of travel, distance of closest approach, trajectory shape, and time-to-event from single-channel audio. Validated use cases: Zero-shot evaluation and mixed-domain training of deep neural networks. Not validated for real-time safety-critical autonomous driving applications.",
  "rai:personalSensitiveInformation": "None",
  "dct:source": [
    {
      "@type": "Dataset",
      "@id": "https://www.kaggle.com/datasets/vafaeii/vs13-dataset",
      "name": "VS13 Vehicle Speed Dataset (Audio)",
      "description": "The primary seed dataset. Real-world vehicle pass-by audio recordings used as stationary source inputs to the DopplerSim physics-based engine. Covers 6 European passenger vehicle classes: KiaSportage, NissanQashqai, Peugeot3008, Peugeot307, RenaultScenic, and VWPassat.",
      "url": "https://www.kaggle.com/datasets/vafaeii/vs13-dataset",
      "publisher": {
        "@type": "Organization",
        "name": "Kaggle / Dataset contributor vafaeii"
      },
      "license": "https://creativecommons.org/licenses/by/4.0/"
    }
  ],
  "prov:wasGeneratedBy": [
    {
      "@type": "prov:Activity",
      "name": "Data Collection and Simulation",
      "description": "Original real-world vehicle pass-by audio was collected in the VS13 dataset. The synthetic subsets were generated using the DopplerSim physics-based audio engine. This engine applied continuous time-domain Doppler warping, geometric spreading attenuation, and convective amplification to stationary source recordings."
    }
  ],
